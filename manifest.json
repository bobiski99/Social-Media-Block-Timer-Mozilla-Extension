{
  "manifest_version": 2,
  "name": "Simple Site Blocker",
  "version": "1.0",

  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Click to adjust settings",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },

  "web_accessible_resources": [
    "blocked.html",
    "blocked.js"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "site-sinirlayici@turgay",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}